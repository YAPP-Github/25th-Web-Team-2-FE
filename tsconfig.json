{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["src/*"],

      // 공통 코드
      "@common/*": ["src/components/common/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@utils/*": ["src/utils/*"],
      "@constants/*": ["src/constants/*"],
      "@styles/*": ["src/styles/*"],
      "@assets/*": ["src/assets/*"],
      "@lib/*": ["src/lib/*"],
      "@schema/*": ["src/schema/*"],
      "@apis/*": ["src/apis/*"],

      // 페이지
      "@edit/*": ["src/app/edit/*"],
      "@home/*": ["src/app/home/*"],
      "@join/*": ["src/app/join/*"],
      "@login/*": ["src/app/login/*"],
      "@my-posts/*": ["src/app/my-posts/*"],
      "@post/*": ["src/app/post/*"],
      "@upload/*": ["src/app/upload/*"],
      "@user/*": ["src/app/user/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
